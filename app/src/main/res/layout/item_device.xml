<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="8dp"
  android:layout_marginBottom="8dp"
  android:clickable="true"
  android:foreground="?attr/selectableItemBackground"
  app:cardBackgroundColor="@color/mako_surface_variant"
  app:cardCornerRadius="20dp"
  app:cardElevation="0dp"
  app:rippleColor="@color/mako_secondary"
  app:strokeColor="@color/mako_stroke_soft"
  app:strokeWidth="1dp">

  <LinearLayout
    android:id="@+id/deviceContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/deviceName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/mako_on_surface"
        android:textSize="16sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/deviceBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:background="@drawable/badge_surface"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:textColor="@color/mako_secondary"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/deviceMeta"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:textColor="@color/mako_on_background" />

    <TextView
      android:id="@+id/deviceHost"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:textColor="@color/mako_secondary"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/deviceStatus"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:textColor="@color/mako_on_background" />
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>
