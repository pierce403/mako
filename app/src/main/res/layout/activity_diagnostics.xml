<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/mako_background"
  android:orientation="vertical">

  <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mako_surface"
    android:elevation="0dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar" />

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/mako_stroke_soft" />

  <androidx.core.widget.NestedScrollView
    android:id="@+id/scrollContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="24dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/panel_surface_subtle"
        android:padding="16dp"
        android:text="@string/diagnostics_warning"
        android:textColor="@color/mako_on_background" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/copyButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/copy_diagnostics_report" />

      <TextView
        android:id="@+id/reportText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:textColor="@color/mako_on_surface"
        android:textIsSelectable="true"
        android:textSize="13sp" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</LinearLayout>
